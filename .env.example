# Server Configuration
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/recruitment-platform

# Gemini AI (Primary)
# Get your API key from: https://makersuite.google.com/app/apikey
# Supported models: gemini-1.5-flash (recommended), gemini-1.5-pro, gemini-1.5-flash-8b
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Groq AI (Fallback — much higher rate limits, free tier)
# Get your free API key from: https://console.groq.com
# Recommended models: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Umurava Platform Integration
UMURAVA_API_URL=https://api.umurava.africa
UMURAVA_API_KEY=your_umurava_api_key_here

# Security
JWT_SECRET=your_jwt_secret_here

# CORS Configuration - Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Logging
LOG_LEVEL=info
